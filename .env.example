# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# DeepSeek AI API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI / Anthropic keys (used by voice + desktop planner)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Desktop computer-use planner
# Options: anthropic | openai | deepseek
COMPUTER_USE_PROVIDER=anthropic
COMPUTER_USE_MODEL=claude-3-5-sonnet-20241022

# Optional local STT adapter (for whisper.cpp / WhisperKit wrappers)
# VOICE_LOCAL_STT_COMMAND=/absolute/path/to/your/stt-wrapper
# VOICE_LOCAL_STT_ARGS_JSON=["--input","{{audio_path}}","--format","json"]
# VOICE_LOCAL_STT_TIMEOUT_MS=20000

# Agent perception policy (default true): capture screenshot each loop step,
# then re-plan the next best click/type/scroll action from latest UI state.
AGENT_SCREENSHOT_EVERY_STEP=true

# Optional: Custom server port (default: 3001)
OAUTH_PORT=3001
