{
  "name": "weave-todo-app",
  "version": "1.0.0",
  "description": "Electron app with Google OAuth and Chrome extension for AI-powered Weave to-do lists",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-extension": "webpack --config extension.webpack.config.js"
  },
  "keywords": [
    "electron",
    "chrome-extension",
    "ai",
    "todo",
    "google-oauth"
  ],
  "author": "Weave Team",
  "license": "MIT",
  "devDependencies": {
    "copy-webpack-plugin": "^11.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.0",
    "google-auth-library": "^9.4.0",
    "googleapis": "^128.0.0",
    "puppeteer-core": "^22.15.0",
    "sqlite3": "^5.1.7",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.weave.todo",
    "productName": "Weave Todo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  }
}
