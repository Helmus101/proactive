{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContactProfile",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "user_id": { "type": "string" },
    "identity": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "category": { "type": "string" },
        "linkedin_url": { "type": "string" },
        "birthday": { "type": "string", "format": "date" }
      }
    },
    "relationship": {
      "type": "object",
      "properties": {
        "strength": { "type": "string", "enum": ["strong","medium","weak","dormant"] },
        "direction": { "type": "string", "enum": ["user_initiates","they_initiate","mutual"] },
        "last_contact": { "type": "string", "format": "date-time" },
        "contact_frequency_per_month": { "type": "number" },
        "first_contact": { "type": "string", "format": "date-time" }
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "summary": { "type": "string" },
          "outcome": { "type": "string" }
        }
      }
    },
    "open_loops": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "due_by": { "type": "string", "format": "date-time" },
          "resolved": { "type": "boolean" }
        }
      }
    },
    "context_for_drafting": {
      "type": "object",
      "properties": {
        "how_we_met": { "type": "string" },
        "shared_topics": { "type": "array", "items": { "type": "string" } },
        "things_to_avoid": { "type": "array", "items": { "type": "string" } },
        "user_blocked": { "type": "boolean" }
      }
    }
  },
  "required": ["id","user_id"]
}
