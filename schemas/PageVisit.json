{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PageVisit",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "user_id": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "domain": { "type": "string" },
    "title": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "number" }
  },
  "required": ["id","user_id","url","timestamp"]
}
