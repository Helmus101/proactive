{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Suggestion",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "user_id": { "type": "string" },
    "title": { "type": "string" },
    "body": { "type": "string" },
    "intent": { "type": "string" },
    "reason": { "type": "string" },
    "plan": { "type": "array", "items": { "type": "string" } },
    "search_queries": { "type": "array", "items": { "type": "string" } },
    "search_queries_messages": { "type": "array", "items": { "type": "string" } },
    "retrieval_thought": { "type": "object" },
    "retrieval_trace": { "type": "object" },
    "source_node_ids": { "type": "array", "items": { "type": "string" } },
    "source_edge_paths": { "type": "array", "items": { "type": "object" } },
    "trigger_summary": { "type": "string" },
    "confidence": { "type": "number" },
    "type": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "object" } },
    "time_window": { "type": "object" },
    "deeplink": { "type": "string" },
    "category": { "type": "string" },
    "assignee": { "type": "string", "enum": ["ai","human"] },
    "study_subject": { "type": ["string", "null"] },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_path": { "type": "array", "items": { "type": "object" } },
    "recommended_action": { "type": "string" },
    "expected_impact": { "type": "string" },
    "suggestion_group": { "type": "string", "enum": ["now", "next", "risk"] },
    "draft_template_id": { "type": "string" },
    "score": { "type": "number" },
    "status": { "type": "string", "enum": ["suggested","shown","accepted","snoozed","ignored","completed"] }
  },
  "required": ["id","title"]
}
